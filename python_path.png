enu-item" data-sidebar="menu-item" class="group/menu-item relative"><!--[--><a data-slot="sidebar-menu-button" data-sidebar="menu-button" data-size="sm" data-active="false" class="peer/menu-button flex w-full items-center gap-2 overflow-hidden rounded-md p-2 text-left outline-hidden ring-sidebar-ring transition-[width,height,padding] focus-visible:ring-2 active:bg-sidebar-accent active:text-sidebar-accent-foreground disabled:pointer-events-none disabled:opacity-50 group-has-data-[sidebar=menu-action]/menu-item:pr-8 aria-disabled:pointer-events-none aria-disabled:opacity-50 data-[active=true]:bg-sidebar-accent data-[active=true]:font-medium data-[active=true]:text-sidebar-accent-foreground data-[state=open]:hover:bg-sidebar-accent data-[state=open]:hover:text-sidebar-accent-foreground group-data-[collapsible=icon]:size-8! group-data-[collapsible=icon]:p-2! [&amp;&gt;span:last-child]:truncate [&amp;&gt;svg]:size-4 [&amp;&gt;svg]:shrink-0 hover:bg-sidebar-accent hover:text-sidebar-accent-foreground h-7 text-xs" href="/privacy/"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check-icon lucide-shield-check"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path><path d="m9 12 2 2 4-4"></path></svg><span>Privacy</span></a><!--]--></li><!--]--><!--]--></ul><!--]--></div><!--]--></div><!--]--></div><div data-slot="sidebar-footer" data-sidebar="footer" class="flex flex-col gap-2 p-2"><!--[--><!--]--></div><!--]--></div></div></div><main data-slot="sidebar-inset" class="bg-background relative flex w-full flex-1 flex-col md:peer-data-[variant=inset]:m-2 md:peer-data-[variant=inset]:ml-0 md:peer-data-[variant=inset]:rounded-xl md:peer-data-[variant=inset]:shadow-sm md:peer-data-[variant=inset]:peer-data-[state=collapsed]:ml-2"><!--[--><div class="h-full w-full"><div class="flex items-stretch xl:w-full animate-fadeInUp"><div class="post-content flex min-w-0 flex-1 flex-col"><article class="mx-auto flex w-full max-w-2xl min-w-0 flex-1 flex-col gap-8 px-4 py-6 md:px-0 lg:py-8"><h1>How to Add Python to Windows PATH</h1><!--[--><div><p><!--[-->There are two ways to add Python to Windows PATH:<!--]--></p><ol><!--[--><li><!--[-->Via the installation of a recent Python version<!--]--></li><li><!--[-->Manually adding an Windows environment variable<!--]--></li><!--]--></ol><h2 id="method-1-install-a-recent-python-version"><a href="#method-1-install-a-recent-python-version"><!--[-->Method 1: Install a Recent Python Version<!--]--></a></h2><p><!--[-->You can easily add Python to Windows PATH by downloading a recent version of Python and then checking the <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->Add python.exe to PATH<!--]--></code></span> box at the bottom of the setup screen:<!--]--></p><p><!--[--><img src="/img/add-python-to-windows-path/python-install-path.webp" alt="Python setup screen"><!--]--></p><p><!--[-->Finish the installation, and you are good to go! You can verify that you correctly added Python to PATH by typing the following command in your Command Prompt and hitting return:<!--]--></p><div class="shadow rounded-xl mb-6" style=""><div class="flex flex-row items-center justify-between text-sm font-medium bg-blue-700 dark:bg-slate-700 rounded-t-xl py-1 pl-4 pr-1"><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" class="iconify iconify--logos" style="" width="1.22em" height="1em" viewBox="0 0 256 210"><rect width="256" height="209.342" rx="5"/><path fill="#FFF" d="M28.241 21.774q-1.283-1.284-3.098-1.284t-3.11 1.296c-.852.852-1.284 1.888-1.284 3.098s.432 2.247 1.284 3.098l13.442 13.442l-13.43 13.43c-.864.864-1.296 1.9-1.308 3.11c.012 1.21.444 2.247 1.296 3.098c.864.852 1.9 1.284 3.098 1.296c1.222 0 2.259-.432 3.123-1.296l14.935-14.947c3.135-3.123 3.135-6.258 0-9.394zm58.545 33.104c-.864-.864-1.913-1.296-3.135-1.296v-.006H54.817v.006c-1.222 0-2.26.432-3.123 1.296s-1.296 1.901-1.296 3.123s.432 2.271 1.296 3.135s1.9 1.296 3.123 1.296v-.006H83.65v.006c1.222 0 2.27-.432 3.135-1.296s1.296-1.913 1.296-3.135s-.432-2.259-1.296-3.123"/></svg><span></span><button class="rounded-md p-1 hover:bg-slate-600"><span><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" class="iconify iconify--lucide" style="" width="1em" height="1em" viewBox="0 0 24 24"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></g></svg></span></button></div><pre class="language-terminal shiki shiki-themes github-dark font-mono text-xs sm:text-sm overflow-scroll no-scrollbar bg-blue-800 dark:bg-slate-800 rounded-b-xl py-4"><!--[--><code><span class="line" line="1"><span>python -V
</span></span></code><!--]--></pre></div><p><!--[-->The returned output should be a version number, e.g., &quot;Python 3.11.1&quot;.<!--]--></p><h2 id="method-2-manually-add-python-to-windows-path"><a href="#method-2-manually-add-python-to-windows-path"><!--[-->Method 2: Manually add Python to Windows PATH<!--]--></a></h2><p><!--[-->If you have Python already installed and it&#39;s not added to PATH yet, you may apply the steps below to manually add Python to Windows PATH.<!--]--></p><h3 id="step-1-navigate-to-the-windows-environment-variables-screen"><a href="#step-1-navigate-to-the-windows-environment-variables-screen"><!--[-->Step 1: Navigate to the Windows Environment Variables Screen<!--]--></a></h3><p><!--[-->Press the <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->Windows Key<!--]--></code></span> + <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->R<!--]--></code></span> on your keyboard to open the Run dialog box
and type <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->sysdm.cpl<!--]--></code></span> to open the System Properties:<!--]--></p><p><!--[--><img src="/img/add-python-to-windows-path/sysdm.webp" alt="Run dialog box"><!--]--></p><p><!--[-->Go to the <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->Advanced<!--]--></code></span> tab and then click on <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->Environment Variables…<!--]--></code></span>:<!--]--></p><p><!--[--><img src="/img/add-python-to-windows-path/system-properties.webp" alt="System Properties box"><!--]--></p><p><!--[-->That should open the <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->Environment Variables<!--]--></code></span> window, where you can add/edit your paths.<!--]--></p><p><!--[--><img src="/img/add-python-to-windows-path/environment-variables.webp" alt="Environment Variables box"><!--]--></p><h3 id="step-2-add-a-path-variable"><a href="#step-2-add-a-path-variable"><!--[-->Step 2: Add a Path variable<!--]--></a></h3><p><!--[-->Under the <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->User variables<!--]--></code></span> box:<!--]--></p><ul><!--[--><li><!--[-->Click on <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->New...<!--]--></code></span> if no <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->Path<!--]--></code></span> variable is present,<!--]--></li><li><!--[-->Otherwise select the <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->Path<!--]--></code></span> variable and then click on <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->Edit…<!--]--></code></span> instead.<!--]--></li><!--]--></ul><p><!--[-->You should then see the <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->New User Variable<!--]--></code></span> box.<!--]--></p><p><!--[--><img src="/img/add-python-to-windows-path/new-environment-variable.webp" alt="New Environment Variable box"><!--]--></p><p><!--[-->Type <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->Path<!--]--></code></span> in the <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->Variable name<!--]--></code></span> field.<!--]--></p><p><!--[-->For the <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->Variable value<!--]--></code></span> you will need to know the path to the Python that is installed on your computer.<!--]--></p><p><!--[-->To find the path, search <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->python<!--]--></code></span>, right click on the relevant search result and click <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->Open file location<!--]--></code></span>:<!--]--></p><p><!--[--><img src="/img/add-python-to-windows-path/search-python.webp" alt="Search box"><!--]--></p><p><!--[-->In the Windows Explorer right click on the Python icon and click on <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->Properties<!--]--></code></span>:<!--]--></p><p><!--[--><img src="/img/add-python-to-windows-path/open-properties.webp" alt="Properties box"><!--]--></p><p><!--[-->Copy the target path without the <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->python.exe<!--]--></code></span> part:<!--]--></p><p><!--[--><img src="/img/add-python-to-windows-path/python-properties.webp" alt="Target path"><!--]--></p><p><!--[-->Here is an example of a <strong><!--[-->Python application path<!--]--></strong>:<!--]--></p><ul><!--[--><li><!--[--><span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->C:\Users\...\Programs\Python\Python311<!--]--></code></span><!--]--></li><!--]--></ul><p><!--[-->You also need the <strong><!--[-->Python Scripts path<!--]--></strong>. The Scripts folder is located within the Python application path:<!--]--></p><ul><!--[--><li><!--[--><span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->C:\Users\...\Python\Python311\Scripts<!--]--></code></span><!--]--></li><!--]--></ul><p><!--[-->Both paths go into the <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->Variable value<!--]--></code></span> field concatenated by a semicolon <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->;<!--]--></code></span>:<!--]--></p><ul><!--[--><li><!--[--><span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->C:\...\Python311;C:\...\Python311\Scripts<!--]--></code></span><!--]--></li><!--]--></ul><p><!--[--><img src="/img/add-python-to-windows-path/new-environment-variable.webp" alt="New Environment Variable box"><!--]--></p><p><!--[-->Finally, hit <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->OK<!--]--></code></span> and you will see your <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->Path<!--]--></code></span> variable in the <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->User variables<!--]--></code></span> section.
Don’t forget to hit <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->OK<!--]--></code></span> in the <span class="bg-white/20 font-mono text-sm rounded px-1 py-0.5"><code><!--[-->Environment Variable<!--]--></code></span> window to confirm your changes.<!--]--></p><p><!--[-->That&#39;s it, you just manually added Python to the Windows Path!<!--]--></p><p><!--[-->You can verify that you correctly added Python to PATH by executing the following command in your Command Prompt:<!--]--></p><div class="shadow rounded-xl mb-6" style=""><div class="flex flex-row items-center justify-between text-sm font-medium bg-blue-700 dark:bg-slate-700 rounded-t-xl py-1 pl-4 pr-1"><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" class="iconify iconify--logos" style="" width="1.22em" height="1em" viewBox="0 0 256 210"><rect width="256" height="209.342" rx="5"/><path fill="#FFF" d="M28.241 21.774q-1.283-1.284-3.098-1.284t-3.11 1.296c-.852.852-1.284 1.888-1.284 3.098s.432 2.247 1.284 3.098l13.442 13.442l-13.43 13.43c-.864.864-1.296 1.9-1.308 3.11c.012 1.21.444 2.247 1.296 3.098c.864.852 1.9 1.284 3.098 1.296c1.222 0 2.259-.432 3.123-1.296l14.935-14.947c3.135-3.123 3.135-6.258 0-9.394zm58.545 33.104c-.864-.864-1.913-1.296-3.135-1.296v-.006H54.817v.006c-1.222 0-2.26.432-3.123 1.296s-1.296 1.901-1.296 3.123s.432 2.271 1.296 3.135s1.9 1.296 3.123 1.296v-.006H83.65v.006c1.222 0 2.27-.432 3.135-1.296s1.296-1.913 1.296-3.135s-.432-2.259-1.296-3.123"/></svg><span></span><button class="rounded-md p-1 hover:bg-slate-600"><span><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" class="iconify iconify--lucide" style="" width="1em" height="1em" viewBox="0 0 24 24"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></g></svg></span></button></div><pre class="language-terminal shiki shiki-themes github-dark font-mono text-xs sm:text-sm overflow-scroll no-scrollbar bg-blue-800 dark:bg-slate-800 rounded-b-xl py-4"><!--[--><code><span class="line" line="1"><span>python -V
</span></span></code><!--]--></pre></div><p><!--[-->The returned output should be a version number, e.g., &quot;Python 3.11.1&quot;.<!--]--></p><style nonce="wWqWawhMh9MiDgzLJIXUNMu2">html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}</style></div><!--]--></article></div><aside class="sticky top-[calc(var(--header-height))] z-30 ml-auto hidden h-[calc(100svh-var(--header-height)-var(--footer-height))] w-(--sidebar-width) flex-col gap-4 overflow-hidden overscroll-none pb-8 xl:flex"><div class="no-scrollbar overflow-y-auto py-8 pr-4 text-sm"><div><p class="group font-medium text-xs text-sidebar-foreground/70 flex-1 items-center gap-1.5 py-1.5 -mt-1.5 mb-2 focus-visible:outline-primary hidden lg:flex"> On this page </p><ul class="toc text-sidebar-foreground/70 pb-4"><!--[--><li id="toc-method-1-install-a-recent-python-version" class="mb-2 rounded-md ml-0 cursor-pointer list-none text-sm last:mb-0"><span class="hover:text-sidebar-foreground">Method 1: Install a Recent Python Version</span><!----></li><li id="toc-method-2-manually-add-python-to-windows-path" class="mb-2 rounded-md ml-0 cursor-pointer list-none text-sm last:mb-0"><span class="hover:text-sidebar-foreground">Method 2: Manually add Python to Windows PATH</span><ul class="my-2 ml-3"><!--[--><li id="toc-step-1-navigate-to-the-windows-environment-variables-screen" class="mb-2 ml-0 cursor-pointer list-none text-xs last:mb-0"><span class="hover:text-sidebar-foreground">Step 1: Navigate to the Windows Environment Variables Screen</span></li><li id="toc-step-2-add-a-path-variable" class="mb-2 ml-0 cursor-pointer list-none text-xs last:mb-0"><span class="hover:text-sidebar-foreground">Step 2: Add a Path variable</span></li><!--]--></ul></li><!--]--></ul></div></div></aside></div></div><!--]--></main></div><footer class="w-full flex flex-col justify-end z-10"><div class="max-w-5xl w-full mx-auto text-xs p-4 lg:hidden"><div class="flex flex-col sm:flex-row gap-9 sm:gap-6 md:gap-9 justify-center items-center font-mono"><div class="flex flex-col gap-3"><ul class="flex flex-col gap-3 items-center"><li><a href="/tutorials/">Tutorials</a></li></ul></div><div class="flex flex-col gap-3"><ul class="flex flex-col gap-3 items-center"><li><a href="/python-tutorials/">Python</a></li></ul></div><div class="flex flex-col gap-3"><ul class="flex flex-col gap-3 items-center"><li><a href="/automation-tutorials/">Automation</a></li></ul></div><div class="flex flex-col gap-3"><ul class="flex flex-col gap-3 items-center"><li><a href="/contact/">Contact</a></li></ul></div><div class="flex flex-col gap-3"><ul class="flex flex-col gap-3 items-center"><li><a href="/privacy/">Privacy</a></li></ul></div><div class="flex flex-col gap-3"><button class="p-1.5 rounded hover:bg-white/10"><span>⋅</span></button></div></div></div><div class="w-full mx-auto text-center text-xs text-foreground/85 font-mono px-4 py-2 tracking-tighter"> Data to Fish © 2026</div></footer><!--]--></div><!--]--></section><!--]--></div><div id="teleports"></div><script nonce="wWqWawhMh9MiDgzLJIXUNMu2" type="application/ld+json" data-nuxt-schema-org="true" data-hid="schema-org-graph">{"@context":"https://schema.org","@graph":[{"@id":"https://datatofish.com/#website","@type":"WebSite","inLanguage":"en","name":"Data to Fish","url":"https://datatofish.com/"},{"@id":"https://datatofish.com/add-python-to-windows-path/#webpage","@type":"WebPage","name":"Add Python to Windows Path","url":"https://datatofish.com/add-python-to-windows-path/","isPartOf":{"@id":"https://datatofish.com/#website"},"potentialAction":[{"@type":"ReadAction","target":["https://datatofish.com/add-python-to-windows-path/"]}]}]}</script><script nonce="wWqWawhMh9MiDgzLJIXUNMu2" type="application/json" data-nuxt-data="nuxt-app" data-ssr="true" id="__NUXT_DATA__">[["ShallowReactive",1],{"data":2,"state":562,"once":574,"_errors":575,"serverRendered":333,"path":338},["ShallowReactive",3],{"/add-python-to-windows-path/":4,"i-logos:terminal":345,"i-lucide:copy":351,"sidebar-pandas":354,"sidebar-python-basics":454,"sidebar-python-data-analytics":495,"sidebar-python-data-visualization":503,"sidebar-python-data-management":512,"sidebar-python-gui":528,"sidebar-julia":535,"sidebar-r":539,"sidebar-excel":546,"sidebar-batch-script":550,"/add-python-to-windows-path/-category-tags":560},{"id":5,"title":6,"body":7,"category":199,"description":13,"extension":331,"meta":332,"navigation":333,"path":334,"seo":335,"short_title":336,"sitemap":337,"stem":339,"tags":340,"__hash__":344},"posts/add-python-to-windows-path.md","How to Add Python to Windows PATH",{"type":8,"value":9,"toc":322},"minimark",[10,14,24,29,37,44,47,63,66,70,73,78,93,99,110,116,123,129,133,140,164,171,177,187,194,204,210,216,222,229,235,242,249,256,263,272,279,283,302,305,308,316,318],[11,12,13],"p",{},"There are two ways to add Python to Windows PATH:",[15,16,17,21],"ol",{},[18,19,20],"li",{},"Via the installation of a recent Python version",[18,22,23],{},"Manually adding an Windows environment variable",[25,26,28],"h2",{"id":27},"method-1-install-a-recent-python-version","Method 1: Install a Recent Python Version",[11,30,31,32,36],{},"You can easily add Python to Windows PATH by downloading a recent version of Python and then checking the ",[33,34,35],"code",{},"Add python.exe to PATH"," box at the bottom of the setup screen:",[11,38,39],{},[40,41],"img",{"alt":42,"src":43},"Python setup screen","/img/add-python-to-windows-path/python-install-path.webp",[11,45,46],{},"Finish the installation, and you are good to go! You can verify that you correctly added Python to PATH by typing the following command in your Command Prompt and hitting return:",[48,49,54],"pre",{"className":50,"code":51,"language":52,"meta":53,"style":53},"language-terminal shiki shiki-themes github-dark","python -V\n","terminal","",[33,55,56],{"__ignoreMap":53},[57,58,61],"span",{"class":59,"line":60},"line",1,[57,62,51],{},[11,64,65],{},"The returned output should be a version number, e.g., \"Python 3.11.1\".",[25,67,69],{"id":68},"method-2-manually-add-python-to-windows-path","Method 2: Manually add Python to Windows PATH",[11,71,72],{},"If you have Python already installed and it's not added to PATH yet, you may apply the steps below to manually add Python to Windows PATH.",[74,75,77],"h3",{"id":76},"step-1-navigate-to-the-windows-environment-variables-screen","Step 1: Navigate to the Windows Environment Variables Screen",[11,79,80,81,84,85,88,89,92],{},"Press the ",[33,82,83],{},"Windows Key"," + ",[33,86,87],{},"R"," on your keyboard to open the Run dialog box\nand type ",[33,90,91],{},"sysdm.cpl"," to open the System Properties:",[11,94,95],{},[40,96],{"alt":97,"src":98},"Run dialog box","/img/add-python-to-windows-path/sysdm.webp",[11,100,101,102,105,106,109],{},"Go to the ",[33,103,104],{},"Advanced"," tab and then click on ",[33,107,108],{},"Environment Variables…",":",[11,111,112],{},[40,113],{"alt":114,"src":115},"System Properties box","/img/add-python-to-windows-path/system-properties.webp",[11,117,118,119,122],{},"That should open the ",[33,120,121],{},"Environment Variables"," window, where you can add/edit your paths.",[11,124,125],{},[40,126],{"alt":127,"src":128},"Environment Variables box","/img/add-python-to-windows-path/environment-variables.webp",[74,130,132],{"id":131},"step-2-add-a-path-variable","Step 2: Add a Path variable",[11,134,135,136,139],{},"Under the ",[33,137,138],{},"User variables"," box:",[141,142,143,154],"ul",{},[18,144,145,146,149,150,153],{},"Click on ",[33,147,148],{},"New..."," if no ",[33,151,152],{},"Path"," variable is present,",[18,155,156,157,159,160,163],{},"Otherwise select the ",[33,158,152],{}," variable and then click on ",[33,161,162],{},"Edit…"," instead.",[11,165,166,167,170],{},"You should then see the ",[33,168,169],{},"New User Variable"," box.",[11,172,173],{},[40,174],{"alt":175,"src":176},"New Environment Variable box","/img/add-python-to-windows-path/new-environment-variable.webp",[11,178,179,180,182,183,186],{},"Type ",[33,181,152],{}," in the ",[33,184,185],{},"Variable name"," field.",[11,188,189,190,193],{},"For the ",[33,191,192],{},"Variable value"," you will need to know the path to the Python that is installed on your computer.",[11,195,196,197,200,201,109],{},"To find the path, search ",[33,198,199],{},"python",", right click on the relevant search result and click ",[33,202,203],{},"Open file location",[11,205,206],{},[40,207],{"alt":208,"src":209},"Search box","/img/add-python-to-windows-path/search-python.webp",[11,211,212,213,109],{},"In the Windows Explorer right click on the Python icon and click on ",[33,214,215],{},"Properties",[11,217,218],{},[40,219],{"alt":220,"src":221},"Properties box","/img/add-python-to-windows-path/open-properties.webp",[11,223,224,225,228],{},"Copy the target path without the ",[33,226,227],{},"python.exe"," part:",[11,230,231],{},[40,232],{"alt":233,"src":234},"Target path","/img/add-python-to-windows-path/python-properties.webp",[11,236,237,238,109],{},"Here is an example of a ",[239,240,241],"strong",{},"Python application path",[141,243,244],{},[18,245,246],{},[33,247,248],{},"C:\\Users\\...\\Programs\\Python\\Python311",[11,250,251,252,255],{},"You also need the ",[239,253,254],{},"Python Scripts path",". The Scripts folder is located within the Python application path:",[141,257,258],{},[18,259,260],{},[33,261,262],{},"C:\\Users\\...\\Python\\Python311\\Scripts",[11,264,265,266,268,269,109],{},"Both paths go into the ",[33,267,192],{}," field concatenated by a semicolon ",[33,270,271],{},";",[141,273,274],{},[18,275,276],{},[33,277,278],{},"C:\\...\\Python311;C:\\...\\Python311\\Scripts",[11,280,281],{},[40,282],{"alt":175,"src":176},[11,284,285,286,289,290,292,293,295,296,182,298,301],{},"Finally, hit ",[33,287,288],{},"OK"," and you will see your ",[33,291,152],{}," variable in the ",[33,294,138],{}," section.\nDon’t forget to hit ",[33,297,288],{},[33,299,300],{},"Environment Variable"," window to confirm your changes.",[11,303,304],{},"That's it, you just manually added Python to the Windows Path!",[11,306,307],{},"You can verify that you correctly added Python to PATH by executing the following command in your Command Prompt:",[48,309,310],{"className":50,"code":51,"language":52,"meta":53,"style":53},[33,311,312],{"__ignoreMap":53},[57,313,314],{"class":59,"line":60},[57,315,51],{},[11,317,65],{},[319,320,321],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":53,"searchDepth":323,"depth":324,"links":325},2,3,[326,327],{"id":27,"depth":323,"text":28},{"id":68,"depth":323,"text":69,"children":328},[329,330],{"id":76,"depth":324,"text":77},{"id":131,"depth":324,"text":132},"md",{},true,"/add-python-to-windows-path",{"title":6,"description":13},"Add Python to Windows Path",{"loc":338},"/add-python-to-windows-path/","add-python-to-windows-path",[341,342,343],"windows","basics","popular","JujmWIsHxbaWUS03aVg2jcy5wFQljJs_3JCr5y0lFLg",{"left":346,"top":346,"width":347,"height":348,"rotate":346,"vFlip":349,"hFlip":349,"body":350},0,256,210,false,"\u003Crect width=\"256\" height=\"209.342\" rx=\"5\"/>\u003Cpath fill=\"#FFF\" d=\"M28.241 21.774q-1.283-1.284-3.0